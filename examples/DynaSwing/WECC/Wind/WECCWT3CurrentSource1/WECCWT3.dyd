<dyn:dynamicModelsArchitecture xmlns:dyn="http://www.rte-france.com/dynawo">
  <dyn:blackBoxModel id="InfBus" lib="InfiniteBusWithVariations" parFile="WECCWT3.par" parId="InfBusPar"/>
  <dyn:blackBoxModel id="WT3" lib="WeccWT3CurrentSource1" parFile="WECCWT3.par" parId="PlantPar"/>
  <dyn:blackBoxModel id="PRefPu" lib="Step" parFile="WECCWT3.par" parId="PRefPu"/>
  <dyn:blackBoxModel id="QRefPu" lib="Step" parFile="WECCWT3.par" parId="QRefPu"/>
  <dyn:blackBoxModel id="PFaRef" lib="Step" parFile="WECCWT3.par" parId="PFaRef"/>
  <dyn:blackBoxModel id="OmegaRefPu" lib="SetPoint" parFile="WECCWT3.par" parId="OmegaRef"/>
  <dyn:blackBoxModel id="Line" lib="Line" parFile="WECCWT3.par" parId="LinePar"/>
  <dyn:connect id1="WT3" var1="WT3_terminal" id2="Line" var2="line_terminal1"/>
  <dyn:connect id1="Line" var1="line_terminal2" id2="InfBus" var2="infiniteBus_terminal"/>
  <dyn:connect id1="WT3" var1="WT3_PConvRefPu" id2="PRefPu" var2="step_step"/>
  <dyn:connect id1="WT3" var1="WT3_QConvRefPu" id2="QRefPu" var2="step_step"/>
  <dyn:connect id1="WT3" var1="WT3_PFaRef" id2="PFaRef" var2="step_step"/>
  <dyn:connect id1="OmegaRefPu" var1="setPoint_setPoint" id2="WT3" var2="WT3_omegaRefPu"/>
</dyn:dynamicModelsArchitecture>
