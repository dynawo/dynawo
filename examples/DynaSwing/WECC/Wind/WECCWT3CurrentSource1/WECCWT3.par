    <par type="BOOL" name="WT3_VFlag" value="true"/>
    <par type="BOOL" name="WT3_PfFlag" value="false"/>
    <par type="BOOL" name="WT3_PQFlag" value="false"/>
    <par type="BOOL" name="WT3_PPriority" value="false"/>
    <par type="DOUBLE" name="WT3_tRv" value="1e-5"/>
    <par type="DOUBLE" name="WT3_UMinPu" value="0.9"/>
    <par type="DOUBLE" name="WT3_UMaxPu" value="1.1"/>
    <par type="DOUBLE" name="WT3_VUpPu" value="1.12"/>
    <par type="DOUBLE" name="WT3_VDipPu" value="0.88"/>
    <par type="DOUBLE" name="WT3_VRef0Pu" value="1"/>
    <par type="DOUBLE" name="WT3_Dbd1Pu" value="-0.1"/>
    <par type="DOUBLE" name="WT3_Dbd2Pu" value="0.1"/>
    <par type="DOUBLE" name="WT3_Kqv" value="2"/>
    <par type="DOUBLE" name="WT3_Iqh1Pu" value="2"/>
    <par type="DOUBLE" name="WT3_Iql1Pu" value="-2"/>
    <par type="DOUBLE" name="WT3_Kqp" value="1e-5"/>
    <par type="DOUBLE" name="WT3_Kqi" value="1"/>
    <par type="DOUBLE" name="WT3_VMaxPu" value="1.2"/>
    <par type="DOUBLE" name="WT3_VMinPu" value="0.8"/>
    <par type="DOUBLE" name="WT3_Kvp" value="1e-5"/>
    <par type="DOUBLE" name="WT3_Kvi" value="1"/>
    <par type="DOUBLE" name="WT3_tIq" value="0.01"/>
    <par type="DOUBLE" name="WT3_tPord" value="0.01"/>
    <par type="DOUBLE" name="WT3_DPMaxPu" value="1"/>
    <par type="DOUBLE" name="WT3_DPMinPu" value="-1"/>
    <par type="DOUBLE" name="WT3_IMaxPu" value="1.2"/>
    <par type="DOUBLE" name="WT3_VDLIp11" value="0"/>
    <par type="DOUBLE" name="WT3_VDLIp12" value="1"/>
    <par type="DOUBLE" name="WT3_VDLIp21" value="0.33"/>
    <par type="DOUBLE" name="WT3_VDLIp22" value="1"/>
    <par type="DOUBLE" name="WT3_VDLIp31" value="0.66"/>
    <par type="DOUBLE" name="WT3_VDLIp32" value="1"/>
    <par type="DOUBLE" name="WT3_VDLIp41" value="1.05"/>
    <par type="DOUBLE" name="WT3_VDLIp42" value="1"/>
    <par type="DOUBLE" name="WT3_VDLIq11" value="1.1"/>
    <par type="DOUBLE" name="WT3_VDLIq12" value="1"/>
    <par type="DOUBLE" name="WT3_VDLIq21" value="1.15"/>
    <par type="DOUBLE" name="WT3_VDLIq22" value="1"/>
    <par type="DOUBLE" name="WT3_VDLIq31" value="1.2"/>
    <par type="DOUBLE" name="WT3_VDLIq32" value="1"/>
    <par type="DOUBLE" name="WT3_VDLIq41" value="1.3"/>
    <par type="DOUBLE" name="WT3_VDLIq42" value="1"/>
    <par type="DOUBLE" name="WT3_VRef1Pu" value="1"/>
    <par type="DOUBLE" name="WT3_tHoldIpMax" value="0"/>
    <par type="DOUBLE" name="WT3_tHoldIq" value="10"/>
    <par type="DOUBLE" name="WT3_IqFrzPu" value="0.42"/>
    <par type="BOOL" name="WT3_PFlag" value="false"/>
    <!-- Generator Control -->
    <par type="DOUBLE" name="WT3_tG" value="0.02"/>
    <par type="DOUBLE" name="WT3_tFilterGC" value="1e-5"/>
    <par type="DOUBLE" name="WT3_IqrMinPu" value="-10"/>
    <par type="DOUBLE" name="WT3_IqrMaxPu" value="10"/>
    <par type="DOUBLE" name="WT3_RrpwrPu" value="5.01"/>
    <par type="BOOL" name="WT3_Lvplsw" value="false"/>
    <par type="DOUBLE" name="WT3_zerox" value="0.5"/>
    <par type="DOUBLE" name="WT3_brkpt" value="0.9"/>
    <par type="DOUBLE" name="WT3_lvpl1" value="1"/>
    <!-- PLL Control -->
    <par type="DOUBLE" name="WT3_KiPLL" value="200"/>
    <par type="DOUBLE" name="WT3_KpPLL" value="30"/>
    <par type="DOUBLE" name="WT3_OmegaMaxPu" value="1.5"/>
    <par type="DOUBLE" name="WT3_OmegaMinPu" value="0.5"/>
