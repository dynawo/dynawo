    <par type="DOUBLE" name="line_XPu" value="0.05"/>
    <par type="DOUBLE" name="line_GPu" value="0"/>
    <par type="DOUBLE" name="line_BPu" value="0"/>
  </set>
  <set id="PlantPar">
    <par type="DOUBLE" name="WT3_P0Pu" value="-0.7"/>
    <par type="DOUBLE" name="WT3_Q0Pu" value="-0.2"/>
    <par type="DOUBLE" name="WT3_U0Pu" value="1.0"/>
    <par type="DOUBLE" name="WT3_UPhase0" value="0.03533563863002929"/>
    <par type="DOUBLE" name="WT3_PPcc0Pu" value="-0.7"/>
    <par type="DOUBLE" name="WT3_QPcc0Pu" value="-0.2"/>
    <par type="DOUBLE" name="WT3_UPcc0Pu" value="1"/>
    <par type="DOUBLE" name="WT3_UPhasePcc0" value="0.03533563863002929"/>
    <par type="DOUBLE" name="WT3_Pm0Pu" value="0.7"/>
    <!-- Electrical Control -->
    <par type="DOUBLE" name="WT3_QMaxREECPu" value="0.4"/>
    <par type="DOUBLE" name="WT3_QMinREECPu" value="-0.4"/>
    <par type="DOUBLE" name="WT3_PMaxREECPu" value="0.9"/>
    <par type="DOUBLE" name="WT3_PMinREECPu" value="0"/>
    <par type="DOUBLE" name="WT3_tpREEC" value="0.03"/>
    <par type="DOUBLE" name="WT3_tpWTGQa" value="0.03"/>
