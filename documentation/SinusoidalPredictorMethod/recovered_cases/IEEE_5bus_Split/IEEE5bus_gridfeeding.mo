  parameter Real IEEE5bus_gridfeeding_GridFeeding2_PLL_Is0[3] = {IEEE5bus_gridfeeding_GridFeeding2_Is0[1], IEEE5bus_gridfeeding_GridFeeding2_Is0[2], IEEE5bus_gridfeeding_GridFeeding2_Is0[3]};
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_PLL_isd0 = IEEE5bus_gridfeeding_GridFeeding2_isd0;
