  parameter Boolean IEEE5bus_gridfeeding_GridFeeding2_Conv_Lim_c_limitsAtInit = true "Has no longer an effect and is only kept for backwards compatibility (the implementation uses now the homotopy operator)";
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_PLL_Vb(quantity = "ElectricPotential", unit = "V") = IEEE5bus_gridfeeding_GridFeeding2_Vb;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_PLL_Ib(quantity = "ElectricCurrent", unit = "A") = IEEE5bus_gridfeeding_GridFeeding2_Ib;
