model IEEE5bus_gridfeeding
  Real IEEE5bus_gridfeeding_Bus2_p_v[3](start = {IEEE5bus_gridfeeding_Bus2_V0[1], IEEE5bus_gridfeeding_Bus2_V0[2], IEEE5bus_gridfeeding_Bus2_V0[3]});
  Real IEEE5bus_gridfeeding_Bus2_p_i[3];
  parameter Real IEEE5bus_gridfeeding_Bus2_V_0 = 1.0 "Voltage magnitude (pu/SI)";
  parameter Real IEEE5bus_gridfeeding_Bus2_angle_0 = 0.0 "Voltage angle (deg)";
  parameter Real IEEE5bus_gridfeeding_Bus2_angle_0_rad(quantity = "Angle", unit = "rad", displayUnit = "deg") = 0.0174532925199433 * IEEE5bus_gridfeeding_Bus2_angle_0 "Voltage angle (radian)";
  parameter Real IEEE5bus_gridfeeding_Bus2_V0[3] = {cos(IEEE5bus_gridfeeding_Bus2_angle_0_rad) * 0.816496580927726 * IEEE5bus_gridfeeding_Bus2_V_0, cos(-2.094395102393195 + IEEE5bus_gridfeeding_Bus2_angle_0_rad) * 0.816496580927726 * IEEE5bus_gridfeeding_Bus2_V_0, cos(2.094395102393195 + IEEE5bus_gridfeeding_Bus2_angle_0_rad) * 0.816496580927726 * IEEE5bus_gridfeeding_Bus2_V_0};
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Un(quantity = "ElectricPotential", unit = "V") = 100000.0 "Nominal voltage";
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_cos_phin = 0.9;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_fn(quantity = "Frequency", unit = "Hz") = 50.0;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Pn(quantity = "Power", unit = "W") = 4000000000.0 "Nominal apparent power (or Pn and cos_phin)";
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Sn(quantity = "Power", unit = "VA") = IEEE5bus_gridfeeding_GridFeeding2_Pn / IEEE5bus_gridfeeding_GridFeeding2_cos_phin;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Lf_pu = 0.6;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Rf_pu = 0.0001221;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Lf_SI(quantity = "Inductance", unit = "H") = IEEE5bus_gridfeeding_GridFeeding2_Lf_pu * IEEE5bus_gridfeeding_GridFeeding2_Zb / IEEE5bus_gridfeeding_GridFeeding2_wb;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Rf_SI(quantity = "Resistance", unit = "Ohm") = IEEE5bus_gridfeeding_GridFeeding2_Rf_pu * IEEE5bus_gridfeeding_GridFeeding2_Zb;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Pref0 = -44444444.44444444 "initial active power reference in SI";
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Qref0 = 33333333.33333333 "initial reactive power reference in SI";
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Pref0_pu = IEEE5bus_gridfeeding_GridFeeding2_Pref0 / IEEE5bus_gridfeeding_GridFeeding2_Sn;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Qref0_pu = IEEE5bus_gridfeeding_GridFeeding2_Qref0 / IEEE5bus_gridfeeding_GridFeeding2_Sn;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_V0(quantity = "ElectricPotential", unit = "V") = 103670.0 "Initial voltage in RMS Line-Line at the connexion point of converter";
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_wb(quantity = "AngularVelocity", unit = "rad/s") = 6.283185307179586 * IEEE5bus_gridfeeding_GridFeeding2_fn;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Tr_i = 0.01;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_zeta_i = 0.7;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_wn_i = 3.0 / IEEE5bus_gridfeeding_GridFeeding2_Tr_i;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Ti_i = 2.0 * IEEE5bus_gridfeeding_GridFeeding2_zeta_i / IEEE5bus_gridfeeding_GridFeeding2_wn_i - IEEE5bus_gridfeeding_GridFeeding2_Rf_pu * (1.0 / IEEE5bus_gridfeeding_GridFeeding2_wn_i / IEEE5bus_gridfeeding_GridFeeding2_wn_i) * IEEE5bus_gridfeeding_GridFeeding2_wb / IEEE5bus_gridfeeding_GridFeeding2_Lf_pu;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Kp_i = 2.0 * IEEE5bus_gridfeeding_GridFeeding2_zeta_i * IEEE5bus_gridfeeding_GridFeeding2_wn_i * IEEE5bus_gridfeeding_GridFeeding2_Lf_pu / IEEE5bus_gridfeeding_GridFeeding2_wb - IEEE5bus_gridfeeding_GridFeeding2_Rf_pu;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Ki_i = IEEE5bus_gridfeeding_GridFeeding2_Kp_i / IEEE5bus_gridfeeding_GridFeeding2_Ti_i;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_vgd0 = IEEE5bus_gridfeeding_GridFeeding2_V0 / IEEE5bus_gridfeeding_GridFeeding2_Vb;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_vgq0 = 0.0;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_isdref = if (-IEEE5bus_gridfeeding_GridFeeding2_Pref0_pu) / IEEE5bus_gridfeeding_GridFeeding2_vgd0 > 1.0 then 1.0 else if (-IEEE5bus_gridfeeding_GridFeeding2_Pref0_pu) / IEEE5bus_gridfeeding_GridFeeding2_vgd0 < -1.0 then -1.0 else (-IEEE5bus_gridfeeding_GridFeeding2_Pref0_pu) / IEEE5bus_gridfeeding_GridFeeding2_vgd0;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_isqref = if IEEE5bus_gridfeeding_GridFeeding2_Qref0_pu / IEEE5bus_gridfeeding_GridFeeding2_vgd0 > 1.0 then 1.0 else if IEEE5bus_gridfeeding_GridFeeding2_Qref0_pu / IEEE5bus_gridfeeding_GridFeeding2_vgd0 < -1.0 then -1.0 else IEEE5bus_gridfeeding_GridFeeding2_Qref0_pu / IEEE5bus_gridfeeding_GridFeeding2_vgd0;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Ub(quantity = "ElectricPotential", unit = "V") = IEEE5bus_gridfeeding_GridFeeding2_Un;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Vb(quantity = "ElectricPotential", unit = "V") = IEEE5bus_gridfeeding_GridFeeding2_Ub;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Ib(quantity = "ElectricCurrent", unit = "A") = 1.732050807568877 * IEEE5bus_gridfeeding_GridFeeding2_Sn / (1.732050807568877 * IEEE5bus_gridfeeding_GridFeeding2_Ub);
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Zb(quantity = "Resistance", unit = "Ohm") = IEEE5bus_gridfeeding_GridFeeding2_Vb / IEEE5bus_gridfeeding_GridFeeding2_Ib;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_wn_pll(quantity = "AngularVelocity", unit = "rad/s") = 314.1592653589793;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_zeta_pll = 0.7;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Kp_pll = 2.0 * IEEE5bus_gridfeeding_GridFeeding2_zeta_pll * IEEE5bus_gridfeeding_GridFeeding2_wn_pll / IEEE5bus_gridfeeding_GridFeeding2_Ub;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Ti_pll = 2.0 * IEEE5bus_gridfeeding_GridFeeding2_zeta_pll / IEEE5bus_gridfeeding_GridFeeding2_wn_pll;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_init_w(quantity = "AngularVelocity", unit = "rad/s") = 6.283185307179586 * IEEE5bus_gridfeeding_GridFeeding2_fn;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_init_theta = -2.64 "in degree";
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_init_theta_rad(quantity = "Angle", unit = "rad", displayUnit = "deg") = 0.0174532925199433 * IEEE5bus_gridfeeding_GridFeeding2_init_theta "in radian";
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_isd0 = IEEE5bus_gridfeeding_GridFeeding2_isdref;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_isq0 = IEEE5bus_gridfeeding_GridFeeding2_isqref;
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Vg0[3] = {IEEE5bus_gridfeeding_GridFeeding2_V0 * cos(IEEE5bus_gridfeeding_GridFeeding2_init_theta_rad) * 0.816496580927726, IEEE5bus_gridfeeding_GridFeeding2_V0 * cos(-2.094395102393195 + IEEE5bus_gridfeeding_GridFeeding2_init_theta_rad) * 0.816496580927726, IEEE5bus_gridfeeding_GridFeeding2_V0 * cos(2.094395102393195 + IEEE5bus_gridfeeding_GridFeeding2_init_theta_rad) * 0.816496580927726};
  parameter Real IEEE5bus_gridfeeding_GridFeeding2_Is0[3] = {0.816496580927726 * (cos(IEEE5bus_gridfeeding_GridFeeding2_init_theta_rad) * IEEE5bus_gridfeeding_GridFeeding2_isd0 - sin(IEEE5bus_gridfeeding_GridFeeding2_init_theta_rad) * IEEE5bus_gridfeeding_GridFeeding2_isq0) * IEEE5bus_gridfeeding_GridFeeding2_Ib, 0.816496580927726 * (cos(-2.094395102393195 + IEEE5bus_gridfeeding_GridFeeding2_init_theta_rad) * IEEE5bus_gridfeeding_GridFeeding2_isd0 - sin(-2.094395102393195 + IEEE5bus_gridfeeding_GridFeeding2_init_theta_rad) * IEEE5bus_gridfeeding_GridFeeding2_isq0) * IEEE5bus_gridfeeding_GridFeeding2_Ib, 0.816496580927726 * (cos(2.094395102393195 + IEEE5bus_gridfeeding_GridFeeding2_init_theta_rad) * IEEE5bus_gridfeeding_GridFeeding2_isd0 - sin(2.094395102393195 + IEEE5bus_gridfeeding_GridFeeding2_init_theta_rad) * IEEE5bus_gridfeeding_GridFeeding2_isq0) * IEEE5bus_gridfeeding_GridFeeding2_Ib};
  Real IEEE5bus_gridfeeding_GridFeeding2_Conv_Vs(quantity = "ElectricPotential", unit = "V") = IEEE5bus_gridfeeding_GridFeeding2_Vs;
  Real IEEE5bus_gridfeeding_GridFeeding2_Conv_fg[3];
  Real IEEE5bus_gridfeeding_GridFeeding2_Conv_p_v[3];
  Real IEEE5bus_gridfeeding_GridFeeding2_Conv_p_i[3];
