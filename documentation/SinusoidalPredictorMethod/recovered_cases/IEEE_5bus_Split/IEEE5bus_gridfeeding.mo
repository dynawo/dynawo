  Real IEEE5bus_gridfeeding_GridFeeding2_PLL_Ws(quantity = "AngularVelocity", unit = "rad/s", start = IEEE5bus_gridfeeding_GridFeeding2_PLL_init_w, fixed = true);
  Real IEEE5bus_gridfeeding_GridFeeding2_PLL_isd(start = IEEE5bus_gridfeeding_GridFeeding2_PLL_isd0) "AC side grid Current axis d in pu";
