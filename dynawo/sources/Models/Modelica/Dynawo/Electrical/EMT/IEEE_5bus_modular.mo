  Ground_p_v2 = V_Sensor_n_v2;
  Ground_p_v3 = V_Sensor_n_v3;
  annotation(preferredView = "text");
end EMT5_GridFeeding;

model Circuit "IEEE 5-bus EMT network: components + connect() topology"
  EMT5_Bus bus1(V_0 = 106000.0, angle_0 = 0.0);
  EMT5_Bus bus2(V_0 = 103670.0, angle_0 = -2.58);
  EMT5_Bus bus3(V_0 = 100710.0, angle_0 = -5.02);
  EMT5_Bus bus4(V_0 = 100600.0, angle_0 = -5.29);
  EMT5_Bus bus5(V_0 = 100130.0, angle_0 = -6.0);
  EMT5_ConstSource cst2(k = 207340.0);
  EMT5_GridFeeding gridFeeding2;
  EMT5_Ground grnd;
  EMT5_PQLoad load2(P = 21460000.0, Q = 10730000.0, V = 103670.0, V0 = 103670.0, init_theta = -2.58);
  EMT5_PQLoad load3(P = 45540000.0, Q = 15180000.0, V = 100710.0, V0 = 100710.0, init_theta = -5.02);
  EMT5_PQLoad load4(P = 40390000.0, Q = 5050000.0, V = 100600.0, V0 = 100600.0, init_theta = -5.29);
  EMT5_PQLoad load5(P = 60030000.0, Q = 10000000.0, V = 100130.0, V0 = 100130.0, init_theta = -6.0);
  EMT5_PerfectGen perfectGen1(V = 106000.0);
  EMT5_RLLine line_1_2(X = 0.1, L = 0.01909859317102744, R = 2.0);
  EMT5_RLLine line_1_3(X = 0.1, L = 0.07639437268410976, R = 8.0);
  EMT5_RLLine line_2_3(X = 0.1, L = 0.07957747154594767, R = 6.0);
  EMT5_RLLine line_2_4(X = 0.1, L = 0.05729577951308232, R = 6.0);
  EMT5_RLLine line_2_5(X = 0.1, L = 0.03819718634205488, R = 4.0);
  EMT5_RLLine line_3_4(X = 0.1, L = 0.00954929658551372, R = 1.0);
  EMT5_RLLine line_4_5(X = 0.1, L = 0.07639437268410976, R = 8.0);
equation
  gridFeeding2.Vs = cst2.y;
  connect(bus2.p, gridFeeding2.p);
  connect(bus2.p, line_1_2.n);
  connect(bus2.p, line_2_3.p);
  connect(bus2.p, line_2_4.p);
  connect(bus2.p, line_2_5.p);
  connect(bus2.p, load2.p);
  connect(bus3.p, line_1_3.n);
  connect(bus3.p, line_2_3.n);
  connect(bus3.p, line_3_4.p);
  connect(bus3.p, load3.p);
  connect(bus4.p, line_2_4.n);
  connect(bus4.p, line_3_4.n);
  connect(bus4.p, line_4_5.p);
  connect(bus4.p, load4.p);
  connect(bus5.p, line_2_5.n);
  connect(bus5.p, line_4_5.n);
  connect(bus5.p, load5.p);
  connect(grnd.p, perfectGen1.n);
  connect(bus1.p, line_1_2.p);
  connect(bus1.p, line_1_3.p);
  connect(bus1.p, perfectGen1.p);
  annotation(preferredView = "text");
end Circuit;
end IEEE_5bus_modular;
