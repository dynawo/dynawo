  parameter Real CurrentControl_PI_sat_q_k(unit = "1") = CurrentControl_Kp_i "Gain";
  parameter Real CurrentControl_PI_sat_q_T(quantity = "Time", unit = "s", min = 1e-60, start = 1.0) = CurrentControl_Ti_i "Time Constant (T>0 required)";
  parameter Real CurrentControl_PI_sat_q_x_start = 0.0 "Initial or guess value of state";
  parameter Real CurrentControl_PI_sat_q_y_start = 0.0 "Initial value of output";
  Real CurrentControl_PI_sat_q_x(start = CurrentControl_PI_sat_q_x_start) "State of block";
  Real RL_converter_p_v1(quantity = "ElectricPotential", unit = "V");
