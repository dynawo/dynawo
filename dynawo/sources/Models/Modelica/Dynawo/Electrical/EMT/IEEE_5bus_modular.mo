  Conv_p_i2 + I_Sensor_p_i2 = 0.0;
  Conv_p_i3 + I_Sensor_p_i3 = 0.0;
  Conv_p_v1 = I_Sensor_p_v1;
  Conv_p_v2 = I_Sensor_p_v2;
  Conv_p_v3 = I_Sensor_p_v3;
  I_Sensor_n_i1 + RL_converter_p_i1 = 0.0;
  I_Sensor_n_i2 + RL_converter_p_i2 = 0.0;
  I_Sensor_n_i3 + RL_converter_p_i3 = 0.0;
  I_Sensor_n_v1 = RL_converter_p_v1;
  I_Sensor_n_v2 = RL_converter_p_v2;
  I_Sensor_n_v3 = RL_converter_p_v3;
  V_Sensor_p_i1 + (-p.i1) + RL_converter_n_i1 = 0.0;
  V_Sensor_p_i2 + (-p.i2) + RL_converter_n_i2 = 0.0;
  V_Sensor_p_i3 + (-p.i3) + RL_converter_n_i3 = 0.0;
  RL_converter_n_v1 = V_Sensor_p_v1;
