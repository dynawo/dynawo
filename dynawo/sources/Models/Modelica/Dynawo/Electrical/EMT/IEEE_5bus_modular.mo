  RL_converter_n_v2 = p.v2;
  RL_converter_n_v3 = V_Sensor_p_v3;
  RL_converter_n_v3 = p.v3;
  V_Sensor_n_i1 + Ground_p_i1 = 0.0;
  V_Sensor_n_i2 + Ground_p_i2 = 0.0;
  V_Sensor_n_i3 + Ground_p_i3 = 0.0;
