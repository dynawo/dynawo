  Real Ground_p_v3(quantity = "ElectricPotential", unit = "V");
  Real Ground_p_i1(quantity = "ElectricCurrent", unit = "A");
  Real Ground_p_i2(quantity = "ElectricCurrent", unit = "A");
  Real Ground_p_i3(quantity = "ElectricCurrent", unit = "A");
  Real Pref(start = Pref0, fixed = true) "Active power reference in SI";
  Real Qref(start = Qref0, fixed = true) "Reactive power reference in SI";
  Real Vs "DC bus voltage";
initial equation
  PLL_PI_PLL_y = PLL_PI_PLL_y_start;
  PLL_Integrator_PLL_y = PLL_Integrator_PLL_y_start;
equation
  Conv_VSource_v1 = Conv_VSource_vs1;
  Conv_VSource_v2 = Conv_VSource_vs2;
  Conv_VSource_v3 = Conv_VSource_vs3;
  Conv_VSource_v1 = Conv_VSource_p_v1 - Conv_VSource_n_v1;
  Conv_VSource_v2 = Conv_VSource_p_v2 - Conv_VSource_n_v2;
  Conv_VSource_v3 = Conv_VSource_p_v3 - Conv_VSource_n_v3;
  0.0 = Conv_VSource_p_i1 + Conv_VSource_n_i1;
  0.0 = Conv_VSource_p_i2 + Conv_VSource_n_i2;
  0.0 = Conv_VSource_p_i3 + Conv_VSource_n_i3;
  Conv_VSource_i1 = Conv_VSource_p_i1;
  Conv_VSource_i2 = Conv_VSource_p_i2;
  Conv_VSource_i3 = Conv_VSource_p_i3;
  Conv_gd_p_v1 = 0.0;
  Conv_gd_p_v2 = 0.0;
  Conv_gd_p_v3 = 0.0;
  Conv_Lim_a_y = homotopy(smooth(0, if Conv_Lim_a_u > Conv_Lim_a_uMax then Conv_Lim_a_uMax else if Conv_Lim_a_u < Conv_Lim_a_uMin then Conv_Lim_a_uMin else Conv_Lim_a_u), Conv_Lim_a_u);
  Conv_Lim_b_y = homotopy(smooth(0, if Conv_Lim_b_u > Conv_Lim_b_uMax then Conv_Lim_b_uMax else if Conv_Lim_b_u < Conv_Lim_b_uMin then Conv_Lim_b_uMin else Conv_Lim_b_u), Conv_Lim_b_u);
  Conv_Lim_c_y = homotopy(smooth(0, if Conv_Lim_c_u > Conv_Lim_c_uMax then Conv_Lim_c_uMax else if Conv_Lim_c_u < Conv_Lim_c_uMin then Conv_Lim_c_uMin else Conv_Lim_c_u), Conv_Lim_c_u);
  Conv_Lim_a_u = Conv_fg1;
  Conv_Lim_b_u = Conv_fg2;
  Conv_Lim_c_u = Conv_fg3;
  Conv_VSource_v1 = 0.5 * Conv_Lim_a_y * Conv_Vs;
  Conv_VSource_v2 = 0.5 * Conv_Lim_b_y * Conv_Vs;
  Conv_VSource_v3 = 0.5 * Conv_Lim_c_y * Conv_Vs;
  PLL_Park_PLL_Concordia_phaseVar_AB0_1 = 0.816496580927726 * (PLL_Park_PLL_Concordia_phaseVar_abc1 + (-0.5) * (PLL_Park_PLL_Concordia_phaseVar_abc2 + PLL_Park_PLL_Concordia_phaseVar_abc3));
  PLL_Park_PLL_Concordia_phaseVar_AB0_2 = 0.816496580927726 * (0.8660254037844386 * PLL_Park_PLL_Concordia_phaseVar_abc2 + (-0.8660254037844386) * PLL_Park_PLL_Concordia_phaseVar_abc3);
  PLL_Park_PLL_Concordia_phaseVar_AB0_3 = 0.5773502691896257 * (PLL_Park_PLL_Concordia_phaseVar_abc1 + PLL_Park_PLL_Concordia_phaseVar_abc2 + PLL_Park_PLL_Concordia_phaseVar_abc3);
  PLL_Park_PLL_phaseVar_abc1 = PLL_Park_PLL_Concordia_phaseVar_abc1;
  PLL_Park_PLL_phaseVar_abc2 = PLL_Park_PLL_Concordia_phaseVar_abc2;
  PLL_Park_PLL_phaseVar_abc3 = PLL_Park_PLL_Concordia_phaseVar_abc3;
  PLL_Park_PLL_phaseVar_dq01 = cos(PLL_Park_PLL_theta) * PLL_Park_PLL_Concordia_phaseVar_AB0_1 + sin(PLL_Park_PLL_theta) * PLL_Park_PLL_Concordia_phaseVar_AB0_2;
  PLL_Park_PLL_phaseVar_dq02 = cos(PLL_Park_PLL_theta) * PLL_Park_PLL_Concordia_phaseVar_AB0_2 - sin(PLL_Park_PLL_theta) * PLL_Park_PLL_Concordia_phaseVar_AB0_1;
  PLL_Park_PLL_phaseVar_dq03 = PLL_Park_PLL_Concordia_phaseVar_AB0_3;
  PLL_Park_Current_Concordia_phaseVar_AB0_1 = 0.816496580927726 * (PLL_Park_Current_Concordia_phaseVar_abc1 + (-0.5) * (PLL_Park_Current_Concordia_phaseVar_abc2 + PLL_Park_Current_Concordia_phaseVar_abc3));
  PLL_Park_Current_Concordia_phaseVar_AB0_2 = 0.816496580927726 * (0.8660254037844386 * PLL_Park_Current_Concordia_phaseVar_abc2 + (-0.8660254037844386) * PLL_Park_Current_Concordia_phaseVar_abc3);
  PLL_Park_Current_Concordia_phaseVar_AB0_3 = 0.5773502691896257 * (PLL_Park_Current_Concordia_phaseVar_abc1 + PLL_Park_Current_Concordia_phaseVar_abc2 + PLL_Park_Current_Concordia_phaseVar_abc3);
  PLL_Park_Current_phaseVar_abc1 = PLL_Park_Current_Concordia_phaseVar_abc1;
  PLL_Park_Current_phaseVar_abc2 = PLL_Park_Current_Concordia_phaseVar_abc2;
  PLL_Park_Current_phaseVar_abc3 = PLL_Park_Current_Concordia_phaseVar_abc3;
  PLL_Park_Current_phaseVar_dq01 = cos(PLL_Park_Current_theta) * PLL_Park_Current_Concordia_phaseVar_AB0_1 + sin(PLL_Park_Current_theta) * PLL_Park_Current_Concordia_phaseVar_AB0_2;
  PLL_Park_Current_phaseVar_dq02 = cos(PLL_Park_Current_theta) * PLL_Park_Current_Concordia_phaseVar_AB0_2 - sin(PLL_Park_Current_theta) * PLL_Park_Current_Concordia_phaseVar_AB0_1;
  PLL_Park_Current_phaseVar_dq03 = PLL_Park_Current_Concordia_phaseVar_AB0_3;
  PLL_Park_Voltage_Concordia_phaseVar_AB0_1 = 0.816496580927726 * (PLL_Park_Voltage_Concordia_phaseVar_abc1 + (-0.5) * (PLL_Park_Voltage_Concordia_phaseVar_abc2 + PLL_Park_Voltage_Concordia_phaseVar_abc3));
  PLL_Park_Voltage_Concordia_phaseVar_AB0_2 = 0.816496580927726 * (0.8660254037844386 * PLL_Park_Voltage_Concordia_phaseVar_abc2 + (-0.8660254037844386) * PLL_Park_Voltage_Concordia_phaseVar_abc3);
  PLL_Park_Voltage_Concordia_phaseVar_AB0_3 = 0.5773502691896257 * (PLL_Park_Voltage_Concordia_phaseVar_abc1 + PLL_Park_Voltage_Concordia_phaseVar_abc2 + PLL_Park_Voltage_Concordia_phaseVar_abc3);
  PLL_Park_Voltage_phaseVar_abc1 = PLL_Park_Voltage_Concordia_phaseVar_abc1;
  PLL_Park_Voltage_phaseVar_abc2 = PLL_Park_Voltage_Concordia_phaseVar_abc2;
  PLL_Park_Voltage_phaseVar_abc3 = PLL_Park_Voltage_Concordia_phaseVar_abc3;
  PLL_Park_Voltage_phaseVar_dq01 = cos(PLL_Park_Voltage_theta) * PLL_Park_Voltage_Concordia_phaseVar_AB0_1 + sin(PLL_Park_Voltage_theta) * PLL_Park_Voltage_Concordia_phaseVar_AB0_2;
  PLL_Park_Voltage_phaseVar_dq02 = cos(PLL_Park_Voltage_theta) * PLL_Park_Voltage_Concordia_phaseVar_AB0_2 - sin(PLL_Park_Voltage_theta) * PLL_Park_Voltage_Concordia_phaseVar_AB0_1;
  PLL_Park_Voltage_phaseVar_dq03 = PLL_Park_Voltage_Concordia_phaseVar_AB0_3;
  der(PLL_PI_PLL_x) = PLL_PI_PLL_u / PLL_PI_PLL_T;
  PLL_PI_PLL_y = PLL_PI_PLL_k * (PLL_PI_PLL_x + PLL_PI_PLL_u);
  der(PLL_Integrator_PLL_y) = PLL_Integrator_PLL_k * PLL_Integrator_PLL_u;
  PLL_Theta = PLL_Park_PLL_theta;
  PLL_Park_PLL_theta = PLL_Integrator_PLL_y;
  PLL_Park_PLL_phaseVar_abc1 = PLL_Vg1;
  PLL_Park_PLL_phaseVar_abc2 = PLL_Vg2;
  PLL_Park_PLL_phaseVar_abc3 = PLL_Vg3;
  PLL_Park_PLL_phaseVar_dq02 = PLL_PI_PLL_u;
  PLL_Integrator_PLL_u = PLL_PI_PLL_y;
  PLL_Ws = PLL_PI_PLL_y;
  PLL_Park_Current_theta = PLL_Theta;
  PLL_Park_Current_phaseVar_abc1 = PLL_Is1 / PLL_Ib;
  PLL_Park_Current_phaseVar_abc2 = PLL_Is2 / PLL_Ib;
  PLL_Park_Current_phaseVar_abc3 = PLL_Is3 / PLL_Ib;
  PLL_isd = PLL_Park_Current_phaseVar_dq01;
  PLL_isq = PLL_Park_Current_phaseVar_dq02;
  PLL_Park_Voltage_theta = PLL_Theta;
  PLL_Park_Voltage_phaseVar_abc1 = PLL_Vg1 / PLL_Vb;
  PLL_Park_Voltage_phaseVar_abc2 = PLL_Vg2 / PLL_Vb;
  PLL_Park_Voltage_phaseVar_abc3 = PLL_Vg3 / PLL_Vb;
  PLL_vgd = PLL_Park_Voltage_phaseVar_dq01;
  PLL_vgq = PLL_Park_Voltage_phaseVar_dq02;
  RefCalculation_Current_Lim_d_y = homotopy(smooth(0, if RefCalculation_Current_Lim_d_u > RefCalculation_Current_Lim_d_uMax then RefCalculation_Current_Lim_d_uMax else if RefCalculation_Current_Lim_d_u < RefCalculation_Current_Lim_d_uMin then RefCalculation_Current_Lim_d_uMin else RefCalculation_Current_Lim_d_u), RefCalculation_Current_Lim_d_u);
  RefCalculation_Current_Lim_q_y = homotopy(smooth(0, if RefCalculation_Current_Lim_q_u > RefCalculation_Current_Lim_q_uMax then RefCalculation_Current_Lim_q_uMax else if RefCalculation_Current_Lim_q_u < RefCalculation_Current_Lim_q_uMin then RefCalculation_Current_Lim_q_uMin else RefCalculation_Current_Lim_q_u), RefCalculation_Current_Lim_q_u);
  RefCalculation_Current_Lim_d_u = (-RefCalculation_Pref) / (RefCalculation_Sn * RefCalculation_Vd_grid);
  RefCalculation_isd_ref = RefCalculation_Current_Lim_d_y;
  RefCalculation_Current_Lim_q_u = RefCalculation_Qref / (RefCalculation_Sn * RefCalculation_Vd_grid);
  RefCalculation_isq_ref = RefCalculation_Current_Lim_q_y;
  CurrentControl_Park_inv_Concordia_phaseVar_AB0_1 = 0.816496580927726 * (CurrentControl_Park_inv_Concordia_phaseVar_abc1 + (-0.5) * (CurrentControl_Park_inv_Concordia_phaseVar_abc2 + CurrentControl_Park_inv_Concordia_phaseVar_abc3));
  CurrentControl_Park_inv_Concordia_phaseVar_AB0_2 = 0.816496580927726 * (0.8660254037844386 * CurrentControl_Park_inv_Concordia_phaseVar_abc2 + (-0.8660254037844386) * CurrentControl_Park_inv_Concordia_phaseVar_abc3);
  CurrentControl_Park_inv_Concordia_phaseVar_AB0_3 = 0.5773502691896257 * (CurrentControl_Park_inv_Concordia_phaseVar_abc1 + CurrentControl_Park_inv_Concordia_phaseVar_abc2 + CurrentControl_Park_inv_Concordia_phaseVar_abc3);
  CurrentControl_Park_inv_phaseVar_abc1 = CurrentControl_Park_inv_Concordia_phaseVar_abc1;
  CurrentControl_Park_inv_phaseVar_abc2 = CurrentControl_Park_inv_Concordia_phaseVar_abc2;
  CurrentControl_Park_inv_phaseVar_abc3 = CurrentControl_Park_inv_Concordia_phaseVar_abc3;
  CurrentControl_Park_inv_phaseVar_dq01 = cos(CurrentControl_Park_inv_theta) * CurrentControl_Park_inv_Concordia_phaseVar_AB0_1 + sin(CurrentControl_Park_inv_theta) * CurrentControl_Park_inv_Concordia_phaseVar_AB0_2;
  CurrentControl_Park_inv_phaseVar_dq02 = cos(CurrentControl_Park_inv_theta) * CurrentControl_Park_inv_Concordia_phaseVar_AB0_2 - sin(CurrentControl_Park_inv_theta) * CurrentControl_Park_inv_Concordia_phaseVar_AB0_1;
  CurrentControl_Park_inv_phaseVar_dq03 = CurrentControl_Park_inv_Concordia_phaseVar_AB0_3;
  der(CurrentControl_fs_d_y) = (CurrentControl_fs_d_k * CurrentControl_fs_d_u - CurrentControl_fs_d_y) / CurrentControl_fs_d_T;
  der(CurrentControl_PI_sat_d_x) = CurrentControl_PI_sat_d_u / CurrentControl_PI_sat_d_T;
  CurrentControl_PI_sat_d_y = CurrentControl_PI_sat_d_k * (CurrentControl_PI_sat_d_x + CurrentControl_PI_sat_d_u);
  der(CurrentControl_fs_q_y) = (CurrentControl_fs_q_k * CurrentControl_fs_q_u - CurrentControl_fs_q_y) / CurrentControl_fs_q_T;
  der(CurrentControl_PI_sat_q_x) = CurrentControl_PI_sat_q_u / CurrentControl_PI_sat_q_T;
  CurrentControl_PI_sat_q_y = CurrentControl_PI_sat_q_k * (CurrentControl_PI_sat_q_x + CurrentControl_PI_sat_q_u);
  CurrentControl_fs_d_u = CurrentControl_isd_ref;
  CurrentControl_PI_sat_d_u = CurrentControl_fs_d_y - CurrentControl_isd;
  CurrentControl_Vd_ref = CurrentControl_PI_sat_d_y + CurrentControl_vgd - CurrentControl_Ws * CurrentControl_isq * CurrentControl_Lf_pu / CurrentControl_wb;
  CurrentControl_fs_q_u = CurrentControl_isq_ref;
  CurrentControl_PI_sat_q_u = CurrentControl_fs_q_y - CurrentControl_isq;
  CurrentControl_Vq_ref = CurrentControl_PI_sat_q_y + CurrentControl_Ws * CurrentControl_isd * CurrentControl_Lf_pu / CurrentControl_wb + CurrentControl_vgq;
  CurrentControl_Park_inv_theta = CurrentControl_Theta;
  CurrentControl_Park_inv_phaseVar_dq01 = CurrentControl_Vd_ref;
  CurrentControl_Park_inv_phaseVar_dq02 = CurrentControl_Vq_ref;
  CurrentControl_Park_inv_phaseVar_dq03 = 0.0;
  CurrentControl_fg1 = 2.0 * CurrentControl_Vb * CurrentControl_Park_inv_phaseVar_abc1 / CurrentControl_Vs;
  CurrentControl_fg2 = 2.0 * CurrentControl_Vb * CurrentControl_Park_inv_phaseVar_abc2 / CurrentControl_Vs;
  CurrentControl_fg3 = 2.0 * CurrentControl_Vb * CurrentControl_Park_inv_phaseVar_abc3 / CurrentControl_Vs;
  RL_converter_v1 = RL_converter_R * RL_converter_i1 + RL_converter_L * der(RL_converter_i1);
  RL_converter_v2 = RL_converter_R * RL_converter_i2 + RL_converter_L * der(RL_converter_i2);
  RL_converter_v3 = RL_converter_R * RL_converter_i3 + RL_converter_L * der(RL_converter_i3);
  RL_converter_v1 = RL_converter_p_v1 - RL_converter_n_v1;
  RL_converter_v2 = RL_converter_p_v2 - RL_converter_n_v2;
  RL_converter_v3 = RL_converter_p_v3 - RL_converter_n_v3;
  0.0 = RL_converter_p_i1 + RL_converter_n_i1;
  0.0 = RL_converter_p_i2 + RL_converter_n_i2;
  0.0 = RL_converter_p_i3 + RL_converter_n_i3;
  RL_converter_i1 = RL_converter_p_i1;
  RL_converter_i2 = RL_converter_p_i2;
  RL_converter_i3 = RL_converter_p_i3;
  I_Sensor_n_v1 = I_Sensor_p_v1;
  I_Sensor_n_v2 = I_Sensor_p_v2;
  I_Sensor_n_v3 = I_Sensor_p_v3;
  I_Sensor_I1 = I_Sensor_i1;
  I_Sensor_I2 = I_Sensor_i2;
  I_Sensor_I3 = I_Sensor_i3;
  I_Sensor_v1 = I_Sensor_p_v1 - I_Sensor_n_v1;
  I_Sensor_v2 = I_Sensor_p_v2 - I_Sensor_n_v2;
  I_Sensor_v3 = I_Sensor_p_v3 - I_Sensor_n_v3;
  0.0 = I_Sensor_p_i1 + I_Sensor_n_i1;
  0.0 = I_Sensor_p_i2 + I_Sensor_n_i2;
  0.0 = I_Sensor_p_i3 + I_Sensor_n_i3;
  I_Sensor_i1 = I_Sensor_p_i1;
  I_Sensor_i2 = I_Sensor_p_i2;
  I_Sensor_i3 = I_Sensor_p_i3;
  V_Sensor_n_i1 = 0.0;
  V_Sensor_n_i2 = 0.0;
  V_Sensor_n_i3 = 0.0;
  V_Sensor_V1 = V_Sensor_p_v1;
  V_Sensor_V2 = V_Sensor_p_v2;
  V_Sensor_V3 = V_Sensor_p_v3;
  V_Sensor_v1 = V_Sensor_p_v1 - V_Sensor_n_v1;
  V_Sensor_v2 = V_Sensor_p_v2 - V_Sensor_n_v2;
  V_Sensor_v3 = V_Sensor_p_v3 - V_Sensor_n_v3;
  0.0 = V_Sensor_p_i1 + V_Sensor_n_i1;
  0.0 = V_Sensor_p_i2 + V_Sensor_n_i2;
  0.0 = V_Sensor_p_i3 + V_Sensor_n_i3;
  V_Sensor_i1 = V_Sensor_p_i1;
  V_Sensor_i2 = V_Sensor_p_i2;
  V_Sensor_i3 = V_Sensor_p_i3;
  Ground_p_v1 = 0.0;
  Ground_p_v2 = 0.0;
  Ground_p_v3 = 0.0;
  CurrentControl_Theta = PLL_Theta;
  CurrentControl_Ws = PLL_Ws;
  CurrentControl_Vs = Vs;
  I_Sensor_I1 = PLL_Is1;
  I_Sensor_I2 = PLL_Is2;
  I_Sensor_I3 = PLL_Is3;
  V_Sensor_V1 = PLL_Vg1;
  V_Sensor_V2 = PLL_Vg2;
  V_Sensor_V3 = PLL_Vg3;
  Pref = Pref0;
  Qref = Qref0;
  Conv_gd_p_i1 + Conv_VSource_n_i1 = 0.0;
  Conv_gd_p_i2 + Conv_VSource_n_i2 = 0.0;
  Conv_gd_p_i3 + Conv_VSource_n_i3 = 0.0;
  Conv_VSource_n_v1 = Conv_gd_p_v1;
  Conv_VSource_n_v2 = Conv_gd_p_v2;
  Conv_VSource_n_v3 = Conv_gd_p_v3;
  Conv_VSource_p_i1 + (-Conv_p_i1) = 0.0;
  Conv_VSource_p_i2 + (-Conv_p_i2) = 0.0;
  Conv_VSource_p_i3 + (-Conv_p_i3) = 0.0;
  Conv_VSource_p_v1 = Conv_p_v1;
  Conv_VSource_p_v2 = Conv_p_v2;
  Conv_VSource_p_v3 = Conv_p_v3;
  Pref = RefCalculation_Pref;
  Qref = RefCalculation_Qref;
  CurrentControl_vgd = PLL_vgd;
  CurrentControl_vgd = RefCalculation_Vd_grid;
  CurrentControl_isd_ref = RefCalculation_isd_ref;
  CurrentControl_isq_ref = RefCalculation_isq_ref;
  CurrentControl_vgq = PLL_vgq;
  CurrentControl_isd = PLL_isd;
  CurrentControl_isq = PLL_isq;
