  parameter Real IEEE_5bus_GridFeeding2_Un(quantity = "ElectricPotential", unit = "V") = 100000.0 "Nominal voltage";
  parameter Real IEEE_5bus_GridFeeding2_cos_phin = 0.9;
  parameter Real IEEE_5bus_GridFeeding2_fn(quantity = "Frequency", unit = "Hz") = 50.0;
  parameter Real IEEE_5bus_GridFeeding2_Pn(quantity = "Power", unit = "W") = 4000000000.0 "Nominal apparent power (or Pn and cos_phin)";
  parameter Real IEEE_5bus_GridFeeding2_Sn(quantity = "Power", unit = "VA") = IEEE_5bus_GridFeeding2_Pn / IEEE_5bus_GridFeeding2_cos_phin;
  parameter Real IEEE_5bus_GridFeeding2_Lf_pu = 0.6;
  parameter Real IEEE_5bus_GridFeeding2_Rf_pu = 0.0001221;
  parameter Real IEEE_5bus_GridFeeding2_Lf_SI(quantity = "Inductance", unit = "H") = IEEE_5bus_GridFeeding2_Lf_pu * IEEE_5bus_GridFeeding2_Zb / IEEE_5bus_GridFeeding2_wb;
  parameter Real IEEE_5bus_GridFeeding2_Rf_SI(quantity = "Resistance", unit = "Ohm") = IEEE_5bus_GridFeeding2_Rf_pu * IEEE_5bus_GridFeeding2_Zb;
  parameter Real IEEE_5bus_GridFeeding2_Pref0 = -44444444.44444444 "initial active power reference in SI";
  parameter Real IEEE_5bus_GridFeeding2_Qref0 = 33333333.33333333 "initial reactive power reference in SI";
  parameter Real IEEE_5bus_GridFeeding2_Pref0_pu = IEEE_5bus_GridFeeding2_Pref0 / IEEE_5bus_GridFeeding2_Sn;
  parameter Real IEEE_5bus_GridFeeding2_Qref0_pu = IEEE_5bus_GridFeeding2_Qref0 / IEEE_5bus_GridFeeding2_Sn;
  parameter Real IEEE_5bus_GridFeeding2_V0(quantity = "ElectricPotential", unit = "V") = 103670.0 "Initial voltage in RMS Line-Line at the connexion point of converter";
  parameter Real IEEE_5bus_GridFeeding2_wb(quantity = "AngularVelocity", unit = "rad/s") = 6.283185307179586 * IEEE_5bus_GridFeeding2_fn;
  parameter Real IEEE_5bus_GridFeeding2_Tr_i = 0.01;
  parameter Real IEEE_5bus_GridFeeding2_zeta_i = 0.7;
  parameter Real IEEE_5bus_GridFeeding2_wn_i = 3.0 / IEEE_5bus_GridFeeding2_Tr_i;
  parameter Real IEEE_5bus_GridFeeding2_Ti_i = 0.004665956317661105;
  parameter Real IEEE_5bus_GridFeeding2_Kp_i = 2.0 * IEEE_5bus_GridFeeding2_zeta_i * IEEE_5bus_GridFeeding2_wn_i * IEEE_5bus_GridFeeding2_Lf_pu / IEEE_5bus_GridFeeding2_wb - IEEE_5bus_GridFeeding2_Rf_pu;
  parameter Real IEEE_5bus_GridFeeding2_Ki_i = IEEE_5bus_GridFeeding2_Kp_i / IEEE_5bus_GridFeeding2_Ti_i;
  parameter Real IEEE_5bus_GridFeeding2_vgd0 = IEEE_5bus_GridFeeding2_V0 / IEEE_5bus_GridFeeding2_Vb;
  parameter Real IEEE_5bus_GridFeeding2_vgq0 = 0.0;
  parameter Real IEEE_5bus_GridFeeding2_isdref = max(min((-IEEE_5bus_GridFeeding2_Pref0_pu) / IEEE_5bus_GridFeeding2_vgd0, 1.0), -1.0);
  parameter Real IEEE_5bus_GridFeeding2_isqref = max(min(IEEE_5bus_GridFeeding2_Qref0_pu / IEEE_5bus_GridFeeding2_vgd0, 1.0), -1.0);
  parameter Real IEEE_5bus_GridFeeding2_Ub(quantity = "ElectricPotential", unit = "V") = IEEE_5bus_GridFeeding2_Un;
  parameter Real IEEE_5bus_GridFeeding2_Vb(quantity = "ElectricPotential", unit = "V") = IEEE_5bus_GridFeeding2_Ub;
  parameter Real IEEE_5bus_GridFeeding2_Ib(quantity = "ElectricCurrent", unit = "A") = 1.732050807568877 * IEEE_5bus_GridFeeding2_Sn / (1.732050807568877 * IEEE_5bus_GridFeeding2_Ub);
  parameter Real IEEE_5bus_GridFeeding2_Zb(quantity = "Resistance", unit = "Ohm") = IEEE_5bus_GridFeeding2_Vb / IEEE_5bus_GridFeeding2_Ib;
  parameter Real IEEE_5bus_GridFeeding2_wn_pll(quantity = "AngularVelocity", unit = "rad/s") = 6.283185307179586 * IEEE_5bus_GridFeeding2_fn;
  parameter Real IEEE_5bus_GridFeeding2_zeta_pll = 0.7;
  parameter Real IEEE_5bus_GridFeeding2_Kp_pll = 2.0 * IEEE_5bus_GridFeeding2_zeta_pll * IEEE_5bus_GridFeeding2_wn_pll / IEEE_5bus_GridFeeding2_Ub;
  parameter Real IEEE_5bus_GridFeeding2_Ti_pll = 2.0 * IEEE_5bus_GridFeeding2_zeta_pll / IEEE_5bus_GridFeeding2_wn_pll;
  parameter Real IEEE_5bus_GridFeeding2_init_w(quantity = "AngularVelocity", unit = "rad/s") = 6.283185307179586 * IEEE_5bus_GridFeeding2_fn;
  parameter Real IEEE_5bus_GridFeeding2_init_theta = -2.64 "in degree";
  parameter Real IEEE_5bus_GridFeeding2_init_theta_rad(quantity = "Angle", unit = "rad", displayUnit = "deg") = 0.0174532925199433 * IEEE_5bus_GridFeeding2_init_theta "in radian";
  parameter Real IEEE_5bus_GridFeeding2_isd0 = IEEE_5bus_GridFeeding2_isdref;
  parameter Real IEEE_5bus_GridFeeding2_isq0 = IEEE_5bus_GridFeeding2_isqref;
  parameter Real IEEE_5bus_GridFeeding2_Vg0_1(quantity = "ElectricPotential", unit = "V") = 0.816496580927726 * IEEE_5bus_GridFeeding2_V0 * cos(IEEE_5bus_GridFeeding2_init_theta_rad);
  parameter Real IEEE_5bus_GridFeeding2_Vg0_2(quantity = "ElectricPotential", unit = "V") = 0.816496580927726 * IEEE_5bus_GridFeeding2_V0 * cos(-2.094395102393195 + IEEE_5bus_GridFeeding2_init_theta_rad);
  parameter Real IEEE_5bus_GridFeeding2_Vg0_3(quantity = "ElectricPotential", unit = "V") = 0.816496580927726 * IEEE_5bus_GridFeeding2_V0 * cos(2.094395102393195 + IEEE_5bus_GridFeeding2_init_theta_rad);
  parameter Real IEEE_5bus_GridFeeding2_Is0_1(quantity = "ElectricCurrent", unit = "A") = 0.816496580927726 * (cos(IEEE_5bus_GridFeeding2_init_theta_rad) * IEEE_5bus_GridFeeding2_isd0 - sin(IEEE_5bus_GridFeeding2_init_theta_rad) * IEEE_5bus_GridFeeding2_isq0) * IEEE_5bus_GridFeeding2_Ib;
  parameter Real IEEE_5bus_GridFeeding2_Is0_2(quantity = "ElectricCurrent", unit = "A") = 0.816496580927726 * (cos(-2.094395102393195 + IEEE_5bus_GridFeeding2_init_theta_rad) * IEEE_5bus_GridFeeding2_isd0 - sin(-2.094395102393195 + IEEE_5bus_GridFeeding2_init_theta_rad) * IEEE_5bus_GridFeeding2_isq0) * IEEE_5bus_GridFeeding2_Ib;
  parameter Real IEEE_5bus_GridFeeding2_Is0_3(quantity = "ElectricCurrent", unit = "A") = 0.816496580927726 * (cos(2.094395102393195 + IEEE_5bus_GridFeeding2_init_theta_rad) * IEEE_5bus_GridFeeding2_isd0 - sin(2.094395102393195 + IEEE_5bus_GridFeeding2_init_theta_rad) * IEEE_5bus_GridFeeding2_isq0) * IEEE_5bus_GridFeeding2_Ib;
  Real IEEE_5bus_GridFeeding2_Conv_Vs(quantity = "ElectricPotential", unit = "V") = IEEE_5bus_GridFeeding2_Vs;
