*
* This file is part of Dynawo, an hybrid C++/Modelica open source time domain simulation tool for power systems.
*
* Shunt-capacitor variant of the recovered EMTSim grid-forming/grid-feeding converter case
* (EMTSim.Examples.GFf_Load_InfBus) via the OMC instantiated-model dump in the
* original IDASPM zip's dynamoCompiler.log. Flat (fully instantiated) form:
* parameters are baked to the original operating point.
*/

model GFf_Load_InfBus_shunt
  parameter Real GFf_Load_InfBus_R_grid(quantity = "Resistance", unit = "Ohm") = 3.0;
  parameter Real GFf_Load_InfBus_L_grid(quantity = "Inductance", unit = "H") = 0.09554140127388536;
  parameter Real GFf_Load_InfBus_ws_pu0 = 1.0;
  parameter Real GFf_Load_InfBus_ed0 = 1.0 "in pu";
  parameter Real GFf_Load_InfBus_eq0 = 0.0 "in pu";
  parameter Real GFf_Load_InfBus_P0_SI(quantity = "Power", unit = "W") = 40000000.0;
  parameter Real GFf_Load_InfBus_Pref0 = -1200000.0 "in W";
  parameter Real GFf_Load_InfBus_Qref0 = 30787.63413 "in Var";
  parameter Real GFf_Load_InfBus_Q0_SI(quantity = "Power", unit = "var") = 4000000.0;
  parameter Real GFf_Load_InfBus_V0(quantity = "ElectricPotential", unit = "V") = 320000.0;
  parameter Real GFf_Load_InfBus_init_theta = 0.0008443055571000001;
  parameter Real GFf_Load_InfBus_init_theta_e(quantity = "Angle", unit = "rad", displayUnit = "deg") = 0.1 "in degree";
  parameter Real GFf_Load_InfBus_V_Load1_0[3] = {255045.0, -146124.0, -108920.0};
  parameter Real GFf_Load_InfBus_V_Load2_0[3] = {0.0, 0.0, 0.0};
  parameter Real GFf_Load_InfBus_V_Load3_0[3] = {0.0, 0.0, 0.0};
  Real GFf_Load_InfBus_RL1_p_v[3];
  Real GFf_Load_InfBus_RL1_p_i[3];
  Real GFf_Load_InfBus_RL1_n_v[3];
  Real GFf_Load_InfBus_RL1_n_i[3];
  Real GFf_Load_InfBus_RL1_v[3];
  Real GFf_Load_InfBus_RL1_i[3];
  parameter Real GFf_Load_InfBus_RL1_X(quantity = "Resistance", unit = "Ohm") = 0.1 "inductance of the RL circuit, default value 0.1 ";
  parameter Real GFf_Load_InfBus_RL1_L(quantity = "Inductance", unit = "H") = GFf_Load_InfBus_L_grid "inductance of the RL circuit";
  parameter Real GFf_Load_InfBus_RL1_R(quantity = "Resistance", unit = "Ohm") = GFf_Load_InfBus_R_grid "resistance of the RL circuit";
  parameter Boolean GFf_Load_InfBus_RL1_pu = false "use of per unit value for the model true/false";
  Real GFf_Load_InfBus_const_y "Connector of Real output signal";
  parameter Real GFf_Load_InfBus_const_k(start = 1.0) = 1.0 "Constant output value";
  Real GFf_Load_InfBus_const1_y "Connector of Real output signal";
  parameter Real GFf_Load_InfBus_const1_k(start = 1.0) = 0.0 "Constant output value";
  Real GFf_Load_InfBus_Us(quantity = "ElectricPotential", unit = "V");
  Real GFf_Load_InfBus_const2_y "Connector of Real output signal";
  parameter Real GFf_Load_InfBus_const2_k(start = 1.0) = 640000.0 "Constant output value";
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Un(quantity = "ElectricPotential", unit = "V") = 320000.0;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Vb(quantity = "ElectricPotential", unit = "V") = GFf_Load_InfBus_converter_Grid_Forming1_Un;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_cos_phin = 0.95782629;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Pn(quantity = "Power", unit = "W") = 1000000000.0;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Sb(quantity = "Power", unit = "VA") = GFf_Load_InfBus_converter_Grid_Forming1_Pn / GFf_Load_InfBus_converter_Grid_Forming1_cos_phin;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Ib(quantity = "ElectricCurrent", unit = "A") = 1.732050807568877 * GFf_Load_InfBus_converter_Grid_Forming1_Pn / GFf_Load_InfBus_converter_Grid_Forming1_cos_phin / (1.732050807568877 * GFf_Load_InfBus_converter_Grid_Forming1_Un);
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_fn(quantity = "Frequency", unit = "Hz") = 50.0;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_wb(quantity = "AngularVelocity", unit = "rad/s") = 6.283185307179586 * GFf_Load_InfBus_converter_Grid_Forming1_fn;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Zb(quantity = "Resistance", unit = "Ohm") = GFf_Load_InfBus_converter_Grid_Forming1_Vb / GFf_Load_InfBus_converter_Grid_Forming1_Ib;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_kffv = 0.0;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Lf_pu = 0.15;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Rf_pu = 0.005;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Cf_pu = 0.066;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Lf_SI(quantity = "Inductance", unit = "H") = GFf_Load_InfBus_converter_Grid_Forming1_Lf_pu * GFf_Load_InfBus_converter_Grid_Forming1_Zb / GFf_Load_InfBus_converter_Grid_Forming1_wb;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Rf_SI(quantity = "Resistance", unit = "Ohm") = GFf_Load_InfBus_converter_Grid_Forming1_Rf_pu * GFf_Load_InfBus_converter_Grid_Forming1_Zb;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Cf_SI(quantity = "Capacitance", unit = "F", min = 0.0) = GFf_Load_InfBus_converter_Grid_Forming1_Cf_pu / (GFf_Load_InfBus_converter_Grid_Forming1_Zb * GFf_Load_InfBus_converter_Grid_Forming1_wb);
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_T_LP = 0.03183098861837907;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_mp = GFf_Load_InfBus_converter_Grid_Forming1_sigma * GFf_Load_InfBus_converter_Grid_Forming1_wb;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_sigma = 0.04;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_P0_SI(quantity = "Power", unit = "W") = GFf_Load_InfBus_P0_SI;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Q0_SI(quantity = "Power", unit = "var") = GFf_Load_InfBus_Q0_SI;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_V0(quantity = "ElectricPotential", unit = "V") = GFf_Load_InfBus_V0;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_ed0 = GFf_Load_InfBus_ed0;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_eq0 = GFf_Load_InfBus_eq0;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_P0_pu = GFf_Load_InfBus_converter_Grid_Forming1_P0_SI / GFf_Load_InfBus_converter_Grid_Forming1_Sb "reference active power (at t = 0) in pu";
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_igd0 = GFf_Load_InfBus_converter_Grid_Forming1_P0_SI / (GFf_Load_InfBus_converter_Grid_Forming1_Ib * GFf_Load_InfBus_converter_Grid_Forming1_V0 * GFf_Load_InfBus_converter_Grid_Forming1_ed0);
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_igq0 = (-GFf_Load_InfBus_converter_Grid_Forming1_Q0_SI) / (GFf_Load_InfBus_converter_Grid_Forming1_Ib * GFf_Load_InfBus_converter_Grid_Forming1_V0 * GFf_Load_InfBus_converter_Grid_Forming1_ed0);
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_isd0 = GFf_Load_InfBus_converter_Grid_Forming1_igd0 - GFf_Load_InfBus_converter_Grid_Forming1_Cf_pu * GFf_Load_InfBus_converter_Grid_Forming1_eq0;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_isq0 = GFf_Load_InfBus_converter_Grid_Forming1_igq0 + GFf_Load_InfBus_converter_Grid_Forming1_Cf_pu * GFf_Load_InfBus_converter_Grid_Forming1_ed0;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e = GFf_Load_InfBus_init_theta_e "in degree";
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e_rad(quantity = "Angle", unit = "rad", displayUnit = "deg") "in radian";
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Vg0[3] = {cos(GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e_rad) * 0.816496580927726 * GFf_Load_InfBus_converter_Grid_Forming1_V0, cos(-2.094395102393195 + GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e_rad) * 0.816496580927726 * GFf_Load_InfBus_converter_Grid_Forming1_V0, cos(2.094395102393195 + GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e_rad) * 0.816496580927726 * GFf_Load_InfBus_converter_Grid_Forming1_V0};
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Ig0[3] = {0.816496580927726 * (cos(GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e_rad) * GFf_Load_InfBus_converter_Grid_Forming1_igd0 - sin(GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e_rad) * GFf_Load_InfBus_converter_Grid_Forming1_igq0) * GFf_Load_InfBus_converter_Grid_Forming1_Ib, 0.816496580927726 * (cos(-2.094395102393195 + GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e_rad) * GFf_Load_InfBus_converter_Grid_Forming1_igd0 - sin(-2.094395102393195 + GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e_rad) * GFf_Load_InfBus_converter_Grid_Forming1_igq0) * GFf_Load_InfBus_converter_Grid_Forming1_Ib, 0.816496580927726 * (cos(2.094395102393195 + GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e_rad) * GFf_Load_InfBus_converter_Grid_Forming1_igd0 - sin(2.094395102393195 + GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e_rad) * GFf_Load_InfBus_converter_Grid_Forming1_igq0) * GFf_Load_InfBus_converter_Grid_Forming1_Ib};
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Is0[3] = {0.816496580927726 * (cos(GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e_rad) * GFf_Load_InfBus_converter_Grid_Forming1_isd0 - sin(GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e_rad) * GFf_Load_InfBus_converter_Grid_Forming1_isq0) * GFf_Load_InfBus_converter_Grid_Forming1_Ib, 0.816496580927726 * (cos(-2.094395102393195 + GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e_rad) * GFf_Load_InfBus_converter_Grid_Forming1_isd0 - sin(-2.094395102393195 + GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e_rad) * GFf_Load_InfBus_converter_Grid_Forming1_isq0) * GFf_Load_InfBus_converter_Grid_Forming1_Ib, 0.816496580927726 * (cos(2.094395102393195 + GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e_rad) * GFf_Load_InfBus_converter_Grid_Forming1_isd0 - sin(2.094395102393195 + GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e_rad) * GFf_Load_InfBus_converter_Grid_Forming1_isq0) * GFf_Load_InfBus_converter_Grid_Forming1_Ib};
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Tr_v = 0.05;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_wn_v = 3.0 / GFf_Load_InfBus_converter_Grid_Forming1_Tr_v;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_zeta_v = 0.7;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Kp_v = 2.0 * GFf_Load_InfBus_converter_Grid_Forming1_zeta_v * GFf_Load_InfBus_converter_Grid_Forming1_wn_v * GFf_Load_InfBus_converter_Grid_Forming1_Cf_pu / GFf_Load_InfBus_converter_Grid_Forming1_wb;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Ti_v = 2.0 * GFf_Load_InfBus_converter_Grid_Forming1_zeta_v / GFf_Load_InfBus_converter_Grid_Forming1_wn_v;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Tr_i = 0.005;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_wn_i = 3.0 / GFf_Load_InfBus_converter_Grid_Forming1_Tr_i;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_zeta_i = 0.7;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Kp_i = 2.0 * GFf_Load_InfBus_converter_Grid_Forming1_zeta_i * GFf_Load_InfBus_converter_Grid_Forming1_wn_i * GFf_Load_InfBus_converter_Grid_Forming1_Lf_pu / GFf_Load_InfBus_converter_Grid_Forming1_wb - GFf_Load_InfBus_converter_Grid_Forming1_Rf_pu;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Ti_i = 0.0023327515569160017;
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_Vs(quantity = "ElectricPotential", unit = "V");
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_fg[3];
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_p_v[3];
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_p_i[3];
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_VSource_p_v[3];
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_VSource_p_i[3];
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_VSource_n_v[3];
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_VSource_n_i[3];
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_VSource_v[3];
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_VSource_i[3];
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_VSource_v1(unit = "V") "Voltage between pin p and n as input signal for phase a";
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_VSource_v2(unit = "V") "Voltage between pin p and n as input signal for phase b";
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_VSource_v3(unit = "V") "Voltage between pin p and n as input signal for phase c";
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_gd_p_v[3];
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_gd_p_i[3];
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_a_u "Connector of Real input signal";
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_a_y "Connector of Real output signal";
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_a_uMax(start = 1.0) = 1.0 "Upper limits of input signals";
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_a_uMin = -GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_a_uMax "Lower limits of input signals";
  parameter Boolean GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_a_strict = false "= true, if strict limits with noEvent(..)";
  parameter Boolean GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_a_limitsAtInit = true "Has no longer an effect and is only kept for backwards compatibility (the implementation uses now the homotopy operator)";
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_b_u "Connector of Real input signal";
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_b_y "Connector of Real output signal";
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_b_uMax(start = 1.0) = 1.0 "Upper limits of input signals";
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_b_uMin = -GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_b_uMax "Lower limits of input signals";
  parameter Boolean GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_b_strict = false "= true, if strict limits with noEvent(..)";
  parameter Boolean GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_b_limitsAtInit = true "Has no longer an effect and is only kept for backwards compatibility (the implementation uses now the homotopy operator)";
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_c_u "Connector of Real input signal";
  Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_c_y "Connector of Real output signal";
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_c_uMax(start = 1.0) = 1.0 "Upper limits of input signals";
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_c_uMin = -GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_c_uMax "Lower limits of input signals";
  parameter Boolean GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_c_strict = false "= true, if strict limits with noEvent(..)";
  parameter Boolean GFf_Load_InfBus_converter_Grid_Forming1_Conv_Lim_c_limitsAtInit = true "Has no longer an effect and is only kept for backwards compatibility (the implementation uses now the homotopy operator)";
  Real GFf_Load_InfBus_converter_Grid_Forming1_ed_ref(start = GFf_Load_InfBus_converter_Grid_Forming1_ed0);
  Real GFf_Load_InfBus_converter_Grid_Forming1_eq_ref(start = GFf_Load_InfBus_converter_Grid_Forming1_eq0);
  Real GFf_Load_InfBus_converter_Grid_Forming1_ws_pu "angular velocity reference in pu";
  Real GFf_Load_InfBus_converter_Grid_Forming1_p_v[3];
  Real GFf_Load_InfBus_converter_Grid_Forming1_p_i[3];
  Real GFf_Load_InfBus_converter_Grid_Forming1_Us "DC bus voltage";
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Vb(quantity = "ElectricPotential", unit = "V") = GFf_Load_InfBus_converter_Grid_Forming1_Vb;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Ib(quantity = "ElectricCurrent", unit = "A") = GFf_Load_InfBus_converter_Grid_Forming1_Ib;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_wb(quantity = "AngularVelocity", unit = "rad/s") = GFf_Load_InfBus_converter_Grid_Forming1_wb;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_T_LP = GFf_Load_InfBus_converter_Grid_Forming1_T_LP;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_mp = GFf_Load_InfBus_converter_Grid_Forming1_mp;
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Vg0[3] = {GFf_Load_InfBus_converter_Grid_Forming1_Vg0[1], GFf_Load_InfBus_converter_Grid_Forming1_Vg0[2], GFf_Load_InfBus_converter_Grid_Forming1_Vg0[3]};
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Ig0[3] = {GFf_Load_InfBus_converter_Grid_Forming1_Ig0[1], GFf_Load_InfBus_converter_Grid_Forming1_Ig0[2], GFf_Load_InfBus_converter_Grid_Forming1_Ig0[3]};
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Is0[3] = {GFf_Load_InfBus_converter_Grid_Forming1_Is0[1], GFf_Load_InfBus_converter_Grid_Forming1_Is0[2], GFf_Load_InfBus_converter_Grid_Forming1_Is0[3]};
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_P0_pu = GFf_Load_InfBus_converter_Grid_Forming1_P0_pu "reference active power (at t = 0) in pu";
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Q0_pu "reference reactive power (at t = 0) in pu";
  parameter Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_init_theta_e = GFf_Load_InfBus_converter_Grid_Forming1_init_theta_e_rad;
  Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_ws_pu "w set point in pu";
  Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Is[3](start = {GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Is0[1], GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Is0[2], GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Is0[3]}, each fixed = true);
  Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Ig[3](start = {GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Ig0[1], GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Ig0[2], GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Ig0[3]}, each fixed = true);
  Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Vg[3](start = {GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Vg0[1], GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Vg0[2], GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Vg0[3]}, each fixed = true);
  Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Ws(quantity = "AngularVelocity", unit = "rad/s");
  Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Theta(quantity = "Angle", unit = "rad", displayUnit = "rad", start = GFf_Load_InfBus_converter_Grid_Forming1_F_cal_init_theta_e);
  Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_isd;
  Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_isq;
  Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_igd;
  Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_igq;
  Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_ed;
  Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_eq;
  Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Park_Vg_phaseVar_abc[3];
  Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Park_Vg_phaseVar_dq0[3];
  Real GFf_Load_InfBus_converter_Grid_Forming1_F_cal_Park_Vg_theta(quantity = "Angle", unit = "rad", displayUnit = "rad") "angle between axis a and axis ir";
