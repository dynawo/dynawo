within Dynawo.Electrical.Controls.Frequency.SystemFrequencyResponse;
record SFRParameters

  parameter Types.PerUnit DPu "Damping coefficient of the swing equation in pu (base SNom/omegaNom)";
  parameter Real Fh "Fraction of the total power generated by the high pressure turbine (0...1)";
  parameter Types.Time H "Inertia constant in s";
  parameter Real Km "Mechanical power gain factor";
  parameter Types.PerUnit R "Governor droop in pu (base omegaNom/SNom)";
  parameter Types.Time Tr "Reheat time constant in s";

  annotation(preferredView = "text");
end SFRParameters;
