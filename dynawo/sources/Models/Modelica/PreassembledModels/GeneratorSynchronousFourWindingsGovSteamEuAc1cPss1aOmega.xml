<dyn:dynamicModelsArchitecture xmlns:dyn="http://www.rte-france.com/dynawo">
  <!-- Machine with four windings and standard IEEE regulations (GovSteamEu, Ac1c, Pss1aOmega). -->
  <dyn:modelicaModel id="GeneratorSynchronousFourWindingsGovSteamEuAc1cPss1aOmega">
    <dyn:unitDynamicModel id="generator" name="Dynawo.Electrical.Machines.OmegaRef.GeneratorSynchronous" initName="Dynawo.Electrical.Machines.OmegaRef.GeneratorSynchronousExt4W_INIT"/>
    <dyn:unitDynamicModel id="voltageRegulator" name="Dynawo.Electrical.Controls.Machines.VoltageRegulators.Standard.Ac1c" initName="Dynawo.Electrical.Controls.Machines.VoltageRegulators.Standard.Ac168_INIT"/>
    <dyn:unitDynamicModel id="governor" name="Dynawo.Electrical.Controls.Machines.Governors.Standard.Steam.GovSteamEu" initName="Dynawo.Electrical.Controls.Machines.Governors.GovernorPmPGen_INIT"/>
    <dyn:unitDynamicModel id="powerSystemStabilizer" name="Dynawo.Electrical.Controls.Machines.PowerSystemStabilizers.Standard.Pss1aOmega"/>
    <dyn:initConnect id1="voltageRegulator" var1="Efd0Pu" id2="generator" var2="Efd0Pu"/>
    <dyn:initConnect id1="voltageRegulator" var1="Ir0Pu" id2="generator" var2="IRotor0Pu"/>
    <dyn:initConnect id1="voltageRegulator" var1="Us0Pu" id2="generator" var2="UStator0Pu"/>
    <dyn:initConnect id1="governor" var1="Pm0Pu" id2="generator" var2="Pm0Pu"/>
    <dyn:initConnect id1="governor" var1="PGen0Pu" id2="generator" var2="PGen0Pu"/>
    <dyn:connect id1="generator" var1="efdPu" id2="voltageRegulator" var2="EfdPu"/>
    <dyn:connect id1="generator" var1="PmPu" id2="governor" var2="PmPu"/>
    <dyn:connect id1="governor" var1="omegaPu" id2="generator" var2="omegaPu"/>
    <dyn:connect id1="governor" var1="fPu" id2="generator" var2="omegaPu"/>
    <dyn:connect id1="governor" var1="PGenPu" id2="generator" var2="PGenPu"/>
    <dyn:connect id1="voltageRegulator" var1="IrPu" id2="generator" var2="IRotorPu"/>
    <dyn:connect id1="voltageRegulator" var1="UPssPu" id2="powerSystemStabilizer" var2="VPssPu"/>
    <dyn:connect id1="voltageRegulator" var1="UsPu" id2="generator" var2="UStatorPu"/>
    <dyn:connect id1="powerSystemStabilizer" var1="omegaPu" id2="generator" var2="omegaPu"/>
  </dyn:modelicaModel>
</dyn:dynamicModelsArchitecture>
