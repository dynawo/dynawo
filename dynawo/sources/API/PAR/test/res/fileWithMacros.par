<parametersSet xmlns="http://www.rte-france.com/dynawo">
  <set id="1">
    <par type="STRING" name="installPath" value="@DYNAWO_INSTALL_DIR@/lib"/>
    <par type="STRING" name="parPath" value="@PAR_PATH@/data.csv"/>
    <par type="STRING" name="combined" value="@DYNAWO_INSTALL_DIR@/share/@PAR_PATH@/file.txt"/>
    <par type="DOUBLE" name="tb" value="30."/>
    <par type="INT" name="int" value="1"/>
    <par type="BOOL" name="boolean" value="true"/>
    <parTable type="STRING" name="paths">
      <par row="1" column="1" value="@DYNAWO_INSTALL_DIR@/bin"/>
      <par row="1" column="2" value="@PAR_PATH@/tables"/>
    </parTable>
  </set>
</parametersSet>
