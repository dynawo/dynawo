<xs:schema version="1.0"
           xmlns:xs="http://www.w3.org/2001/XMLSchema"
           elementFormDefault="unqualified">

  <xs:element name="mandatoryParameters">
    <xs:complexType>
      <xs:sequence>
        <xs:element name="mandatoryParameter" type="MandatoryParameter" minOccurs="0" maxOccurs="unbounded"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>

  <xs:complexType name="MandatoryParameter">
    <xs:attribute name="name" use="required" type="xs:string"/>
    <xs:attribute name="type" use="required" type="ParameterType"/>
  </xs:complexType>

  <xs:simpleType name="ParameterType">
    <xs:restriction base="xs:string">
      <xs:enumeration value="DOUBLE"/>
      <xs:enumeration value="INT"/>
      <xs:enumeration value="BOOL"/>
      <xs:enumeration value="STRING"/>
    </xs:restriction>
  </xs:simpleType>

</xs:schema>
